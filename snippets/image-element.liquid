{% comment %}
  {% render 'image-element',
    image: recommendation.featured_image,
    widths: '100, 200, 300, 375, 550, 750, 1100, 1500, 1780',
    sizes: '(max-width: 989px) 100vw, 45vw',
    class: 'tw-w-full tw-block tw-object-contain tw-h-auto'
  %}
{% endcomment %}

{%- if image != blank -%}
  {%- liquid
    assign sizes = sizes | default: '100vw'
    if ignore_auto_priority != true
      comment
        Priority resolution (most specific wins):
        1. Explicit caller intent: loading/fetchpriority/eager/priority args.
        2. LCP heuristic: the first section on the page (only works when the caller
           passes `section: section`, since `section` is not in a render snippet's scope).
        3. Safe default: lazy. Previously this defaulted to eager, and because
           `section` is nil inside a rendered snippet the old `section.index > 1`
           test always fell through to eager — so every image loaded eagerly.
      endcomment
      if loading == 'eager' or fetchpriority == 'high' or eager == true or priority == 'high'
        assign lazy_loading = 'eager'
        assign fetch_priority = 'high'
      elsif loading == 'lazy' or lazyload == true
        assign lazy_loading = 'lazy'
        assign fetch_priority = 'low'
      elsif section.index == 1
        assign lazy_loading = 'eager'
        assign fetch_priority = 'high'
      else
        assign lazy_loading = 'lazy'
        assign fetch_priority = 'low'
      endif
    endif
    assign image_class = class
    comment
      Always emit BOTH width and height so the browser can reserve space (prevents CLS).
      This previously derived height as `image.width | divided_by: image.aspect_ratio`,
      which returns nil whenever aspect_ratio is nil or 0 (e.g. some SVG uploads). That
      dropped both attributes and DevTools flagged the result as an "Unsized image"
      layout-shift culprit. Prefer the image's own intrinsic height, and only derive a
      height when the caller has explicitly scaled the width.
    endcomment
    assign image_width = image_width | default: image.width
    assign image_height = image.height
    if image_width != image.width and image.aspect_ratio > 0
      assign image_height = image_width | divided_by: image.aspect_ratio
    endif
    comment
      Cap the fallback src at a sane resolution so non-srcset clients (and crawlers)
      never download the full-native image (e.g. 4000px / 4MB). The srcset from
      `widths` still scales up as needed for high-DPR screens.
    endcomment
    assign src_width = image.width | at_most: 1500
  -%}
  {%- assign alt_text = image.alt | default: image | split: '?' | first | split: '/' | last | split: '.' | first -%}

  {{-
    image
    | image_url: width: src_width
    | image_tag:
      class: image_class,
      width: image_width,
      height: image_height,
      sizes: sizes,
      widths: widths,
      loading: lazy_loading,
      fetchpriority: fetch_priority,
      alt: alt_text
    | escape
  -}}
{%- endif -%}
 